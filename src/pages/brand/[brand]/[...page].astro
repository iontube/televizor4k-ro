---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import products from '../../../data/recomandari.json';

export function getStaticPaths() {
  const MIN_BRAND = 4;
  const PAGE_SIZE = 48;
  const byBrand = {};
  for (const p of products) if (p.brandSlug) (byBrand[p.brandSlug] ||= []).push(p);
  const paths = [];
  for (const [bslug, items] of Object.entries(byBrand)) {
    if (items.length < MIN_BRAND) continue;
    items.sort((a, b) => b.price - a.price);
    const last = Math.ceil(items.length / PAGE_SIZE);
    for (let pg = 1; pg <= last; pg++) {
      paths.push({
        params: { brand: bslug, page: pg === 1 ? undefined : String(pg) },
        props: { brandName: items[0].brand, bslug, items: items.slice((pg - 1) * PAGE_SIZE, pg * PAGE_SIZE), currentPage: pg, lastPage: last, totalCount: items.length },
      });
    }
  }
  return paths;
}

const { brandName, bslug, items, currentPage, lastPage, totalCount } = Astro.props;
const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const enc = (s) => Buffer.from(s, 'utf8').toString('base64');
const year = new Date().getFullYear();
const base = `/brand/${bslug}/`;
const pageMod = items.reduce((m, p) => (p.modified && p.modified > m ? p.modified : m), '2026-03-30');
const title = currentPage === 1 ? `Televizoare 4K ${brandName}: ${totalCount} modele și prețuri ${year} | televizor4k.ro` : `Televizoare 4K ${brandName} – pagina ${currentPage} | televizor4k.ro`;
const desc = `Toate televizoarele 4K ${brandName} din magazinele partenere: ${totalCount} de modele LED, QLED, OLED și Mini LED, cu prețuri actualizate. Găsește cel mai bun model ${brandName}.`;
---
<Layout title={title} description={desc} modified={pageMod}>
  <Nav />
  <section class="rec-sec">
    <div class="wrap">
      <nav class="rec-bc"><a href="/">Acasă</a> › <a href="/recomandari/">Televizoare 4K</a> › <span>{brandName}</span></nav>
      <div class="sec-head">
        <span class="sec-head__tag">Brand</span>
        <h1>Televizoare 4K {brandName}</h1>
        <p><strong>{totalCount}</strong> de televizoare 4K {brandName} din magazinele partenere, cu prețuri actualizate periodic.{lastPage > 1 ? ` Pagina ${currentPage} din ${lastPage}.` : ''}</p>
      </div>

      <div class="products">
        {items.map((p) => (
          <article class="card">
            {p.oldPrice && <span class="card__badge card__badge--value">-{Math.round((1 - p.price / p.oldPrice) * 100)}%</span>}
            <a class="card__img" href={`/tv/${p.slug}/`} aria-label={p.name}><img src={p.img} alt={p.name} width="200" height="200" loading="lazy" decoding="async" /></a>
            <div class="card__body">
              <a href={`/tv/${p.slug}/`}><h3 class="card__name">{p.name}</h3></a>
              <div class="card__specs">{Object.values(p.specs).slice(1, 4).map((v) => <span class="card__spec">{v}</span>)}</div>
              <div class="card__price-row"><span class="card__price">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}</div>
              <div class="card__foot"><a href={`/tv/${p.slug}/`} class="card__cta">Vezi detalii</a></div>
            </div>
          </article>
        ))}
      </div>

      {lastPage > 1 && (
        <nav class="rec-pager" aria-label="Paginare">
          {currentPage > 1 ? <a class="rec-pg" href={currentPage === 2 ? base : `${base}${currentPage - 1}/`}>← Anterioarele</a> : <span class="rec-pg rec-pg--off">← Anterioarele</span>}
          <span class="rec-pg-now">Pagina {currentPage} / {lastPage}</span>
          {currentPage < lastPage ? <a class="rec-pg" href={`${base}${currentPage + 1}/`}>Următoarele →</a> : <span class="rec-pg rec-pg--off">Următoarele →</span>}
        </nav>
      )}

      <p class="rec-back"><a href="/recomandari/">← Vezi toate televizoarele 4K</a></p>
    </div>
  </section>
  <Footer />
</Layout>
