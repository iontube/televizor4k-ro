---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import products from '../../data/recomandari.json';

export function getStaticPaths({ paginate }) {
  const sorted = [...products].sort((a, b) => b.price - a.price);
  return paginate(sorted, { pageSize: 48 });
}

const { page } = Astro.props;
const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const enc = (s) => Buffer.from(s, 'utf8').toString('base64');
const total = products.length;
const pageMod = page.data.reduce((m, p) => (p.modified && p.modified > m ? p.modified : m), '2026-03-30');
const brandList = Object.entries(products.reduce((a, p) => { if (p.brandSlug) a[p.brandSlug] = a[p.brandSlug] || { n: p.brand, s: p.brandSlug, c: 0 }, p.brandSlug && a[p.brandSlug].c++; return a; }, {})).map(([, v]) => v).filter((b) => b.c >= 4).sort((a, b) => b.c - a.c);
const merchList = Object.values(products.reduce((a, p) => { if (p.merchantSlug) a[p.merchantSlug] = a[p.merchantSlug] || { n: p.merchantName, s: p.merchantSlug, c: 0 }, p.merchantSlug && a[p.merchantSlug].c++; return a; }, {})).sort((a, b) => b.c - a.c);
const title = page.currentPage === 1
  ? `Televizoare 4K: ${total} modele recomandate ${new Date().getFullYear()} | televizor4k.ro`
  : `Televizoare 4K – pagina ${page.currentPage} din ${page.lastPage} | televizor4k.ro`;
const desc = `Toate televizoarele 4K din magazinele partenere: ${total} de modele LED, QLED, OLED și Mini LED, de la 43" la 115", cu prețuri actualizate.${page.currentPage > 1 ? ` Pagina ${page.currentPage}.` : ''}`;
---
<Layout title={title} description={desc} modified={pageMod}>
  <Nav />
  <section class="rec-sec">
    <div class="wrap">
      <nav class="rec-bc"><a href="/">Acasă</a> › <span>Recomandări televizoare 4K</span></nav>
      <div class="sec-head">
        <span class="sec-head__tag">Recomandări</span>
        <h1>Televizoare 4K recomandate</h1>
        <p><strong>{total}</strong> de televizoare 4K din magazinele partenere — LED, QLED, OLED și Mini LED, de la 43&quot; la 115&quot;, cu prețuri actualizate periodic. Pagina {page.currentPage} din {page.lastPage}.</p>
      </div>

      <div class="products">
        {page.data.map((p) => (
          <article class="card">
            {p.oldPrice && <span class="card__badge card__badge--value">-{Math.round((1 - p.price / p.oldPrice) * 100)}%</span>}
            <a class="card__img" href={`/tv/${p.slug}/`} aria-label={p.name}>
              <img src={p.img} alt={p.name} width="200" height="200" loading="lazy" decoding="async" />
            </a>
            <div class="card__body">
              <a href={`/tv/${p.slug}/`}><h3 class="card__name">{p.name}</h3></a>
              <div class="card__specs">{Object.values(p.specs).slice(1, 4).map((v) => <span class="card__spec">{v}</span>)}</div>
              <div class="card__price-row"><span class="card__price">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}</div>
              <div class="card__foot"><a href={`/tv/${p.slug}/`} class="card__cta">Vezi detalii</a></div>
            </div>
          </article>
        ))}
      </div>

      <nav class="rec-pager" aria-label="Paginare">
        {page.url.prev ? <a class="rec-pg" href={page.url.prev}>← Anterioarele</a> : <span class="rec-pg rec-pg--off">← Anterioarele</span>}
        <span class="rec-pg-now">Pagina {page.currentPage} / {page.lastPage}</span>
        {page.url.next ? <a class="rec-pg" href={page.url.next}>Următoarele →</a> : <span class="rec-pg rec-pg--off">Următoarele →</span>}
      </nav>

      <div class="rec-links">
        <h2>Televizoare 4K după brand</h2>
        <div class="rec-links__row">{brandList.map((b) => <a class="rec-pg" href={`/brand/${b.s}/`}>{b.n} <span>({b.c})</span></a>)}</div>
      </div>
      <div class="rec-links">
        <h2>Televizoare 4K după magazin</h2>
        <div class="rec-links__row">{merchList.map((m) => <a class="rec-pg" href={`/magazin/${m.s}/`}>{m.n} <span>({m.c})</span></a>)}</div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
