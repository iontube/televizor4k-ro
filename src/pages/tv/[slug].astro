---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import products from '../../data/recomandari.json';

const MIN_BRAND = 4;
const brandCount = {};
for (const x of products) if (x.brandSlug) brandCount[x.brandSlug] = (brandCount[x.brandSlug] || 0) + 1;

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const enc = (s) => Buffer.from(s, 'utf8').toString('base64');
const year = new Date().getFullYear();
const title = `${p.name} – preț și review ${year} | televizor4k.ro`;
const desc = `${p.name} la ${money(p.price)}${p.oldPrice ? ` (redus de la ${money(p.oldPrice)})` : ''} de la ${p.merchant}. Specificații, păreri și unde îl cumperi cel mai avantajos.`;
const hasBrandPage = p.brandSlug && brandCount[p.brandSlug] >= MIN_BRAND;
const related = products.filter((x) => x.band === p.band && x.slug !== p.slug).slice(0, 8);
const off = p.oldPrice ? Math.round((1 - p.price / p.oldPrice) * 100) : 0;
const schema = [
  { '@context': 'https://schema.org', '@type': 'Product', name: p.name, image: p.img, ...(p.brand ? { brand: { '@type': 'Brand', name: p.brand } } : {}), description: p.prose.intro.slice(0, 300),
    offers: { '@type': 'Offer', price: p.price.toFixed(2), priceCurrency: 'RON', availability: 'https://schema.org/InStock', seller: { '@type': 'Organization', name: p.merchant }, url: `https://televizor4k.ro/tv/${p.slug}/` } },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: p.prose.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasă', item: 'https://televizor4k.ro/' },
    { '@type': 'ListItem', position: 2, name: 'Televizoare 4K', item: 'https://televizor4k.ro/recomandari/' },
    ...(hasBrandPage ? [{ '@type': 'ListItem', position: 3, name: p.brand, item: `https://televizor4k.ro/brand/${p.brandSlug}/` }] : []),
    { '@type': 'ListItem', position: hasBrandPage ? 4 : 3, name: p.name, item: `https://televizor4k.ro/tv/${p.slug}/` },
  ] },
];
---
<Layout title={title} description={desc} modified={p.modified}>
  <Nav />
  <section class="tvp-sec">
    <div class="wrap">
      <nav class="rec-bc"><a href="/">Acasă</a> › <a href="/recomandari/">Televizoare 4K</a> ›{hasBrandPage && <> <a href={`/brand/${p.brandSlug}/`}>{p.brand}</a> ›</>} <span>{p.name}</span></nav>

      <article class="tvp-main">
        <div class="tvp-gallery"><img src={p.img} alt={p.name} width="460" height="345" fetchpriority="high" decoding="async" /></div>
        <div class="tvp-offer">
          {p.brand && (hasBrandPage ? <a class="tvp-brand" href={`/brand/${p.brandSlug}/`}>{p.brand}</a> : <span class="tvp-brand">{p.brand}</span>)}
          <h1 class="tvp-h1">{p.name}</h1>
          <div class="tvp-price"><span class="tvp-now">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}{off > 0 && <span class="tvp-off">-{off}%</span>}</div>
          <p class="tvp-stock">Disponibil la <a class="tvp-merch" href={`/magazin/${p.merchantSlug}/`}><strong>{p.merchantName || p.merchant}</strong></a></p>
          <button class="tvp-cta" data-o={enc(p.slug)} type="button">Vezi oferta la {p.merchantName || p.merchant} →</button>
          <p class="tvp-note">Preț actualizat periodic · link afiliat</p>
        </div>
      </article>

      <section class="tvp-block">
        <div class="sec-head"><h2>Despre {p.name}</h2></div>
        <div class="guide">
          <p>{p.prose.intro}</p>
          {p.prose.guide.map((g) => <p>{g}</p>)}
        </div>
      </section>

      <section class="tvp-block">
        <div class="sec-head"><h2>Specificații {p.name}</h2></div>
        <div class="guide">
          <table class="spec-tbl"><tbody>{Object.entries(p.specs).map(([k, v]) => <tr><th>{k}</th><td>{v}</td></tr>)}</tbody></table>
        </div>
      </section>

      <section class="tvp-block">
        <div class="sec-head"><h2>Întrebări frecvente despre {p.name}</h2></div>
        <div class="faq-grid">{p.prose.faq.map((f) => (
          <div class="faq-card">
            <button class="faq-card__q" aria-expanded="false">{f.q}</button>
            <div class="faq-card__a">{f.a}</div>
          </div>
        ))}</div>
      </section>

      {related.length > 0 && (
        <section class="tvp-block">
          <div class="sec-head"><h2>Alte televizoare 4K similare</h2></div>
          <div class="products">{related.map((r) => (
            <article class="card">
              <a class="card__img" href={`/tv/${r.slug}/`}><img src={r.img} alt={r.name} width="200" height="200" loading="lazy" decoding="async" /></a>
              <div class="card__body">
                <a href={`/tv/${r.slug}/`}><h3 class="card__name">{r.name}</h3></a>
                <div class="card__price-row"><span class="card__price">{money(r.price)}</span></div>
                <div class="card__foot"><a href={`/tv/${r.slug}/`} class="card__cta">Vezi detalii</a></div>
              </div>
            </article>
          ))}</div>
        </section>
      )}
    </div>
  </section>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
