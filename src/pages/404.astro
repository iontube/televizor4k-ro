---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Pagină negăsită (404) | televizor4k.ro" description="Pagina căutată nu există sau a fost mutată.">
  <Nav />
  <section class="tvp-sec">
    <div class="wrap" style="text-align:center;max-width:640px">
      <div class="sec-head"><h1>404 — pagina nu există</h1></div>
      <p style="color:var(--ink-mid);margin-bottom:1.6rem">Pagina căutată nu mai există sau adresa este greșită. Poate televizorul căutat nu mai este disponibil în magazinele partenere.</p>
      <p><a href="/recomandari/" class="rec-pg">Vezi toate televizoarele 4K →</a> &nbsp; <a href="/" class="rec-pg">Acasă</a></p>
    </div>
  </section>
  <Footer />
</Layout>
