---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Politica de cookies – televizor4k.ro" description="Politica de cookies a site-ului televizor4k.ro.">
  <Nav />
  <div class="legal">
    <div class="wrap">
      <a href="/" class="back-link">&larr; Inapoi</a>
      <h1>Politica de cookies</h1>
      <h2>Ce sunt cookies?</h2>
      <p>Cookies sunt fisiere text mici stocate in browserul dumneavoastra cand vizitati un site web.</p>
      <h2>Ce cookies folosim</h2>
      <ul>
        <li><strong>Cookies esentiale</strong> - necesare pentru functionarea site-ului (ex: consimtamant cookies)</li>
        <li><strong>Cookies de analiza</strong> - ne ajuta sa intelegem cum este folosit site-ul</li>
      </ul>
      <h2>Cum poti controla cookies</h2>
      <p>Poti sterge sau bloca cookies din setarile browserului. Dezactivarea cookies poate afecta experienta pe site.</p>
      <h2>Contact</h2>
      <p>Pentru intrebari legate de cookies, ne poti contacta prin pagina de <a href="/contact/">Contact</a>.</p>
    </div>
  </div>
  <Footer />
</Layout>
